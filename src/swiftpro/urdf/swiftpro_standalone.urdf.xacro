<?xml version="1.0"?>
<robot name="swiftpro" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:arg name="manipulator_namespace" default="swiftpro" />
  
  <xacro:include filename="$(find swiftpro_description)/urdf/swiftpro.urdf.xacro" />
  <xacro:include filename="$(find swiftpro)/urdf/swiftpro.ros2_control.urdf.xacro" />

  <xacro:swiftpro prefix="$(arg manipulator_namespace)"/>
  <xacro:swiftpro_ros2_control prefix="$(arg manipulator_namespace)"/>
</robot>